# Copy to .env and fill in values. Never commit .env.

# --- Database ---
SCALP_DB_URL=postgresql+psycopg://scalp:scalp@localhost:5432/scalp

# --- Upstox (primary broker) ---
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:8000/upstox/callback
UPSTOX_ACCESS_TOKEN=

# --- Kite Connect (deferred; paper phase) ---
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# --- Free data sources ---
QUANDL_API_KEY=
NSE_BHAVCOPY_CACHE_DIR=./data/cache/bhavcopy

# --- Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Risk caps (INR) ---
SCALP_CAPITAL=100000
SCALP_MAX_DAILY_LOSS=2000
SCALP_KELLY_FRACTION=0.25

# --- Runtime ---
SCALP_ENV=dev
SCALP_LOG_LEVEL=INFO
