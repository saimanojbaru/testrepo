# Upstox API (free)
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_SECRET_KEY=your_upstox_secret_key

# Zerodha Kite Connect (fallback, ₹2000/month)
KITE_API_KEY=your_kite_api_key
KITE_ACCESS_TOKEN=your_kite_access_token

# Data sources
QUANDL_API_KEY=your_quandl_api_key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/scalping_agent
TIMESCALEDB_URL=postgresql://user:password@localhost:5432/scalping_agent

# Monitoring
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Broker settings
PRIMARY_BROKER=upstox  # upstox or kite
TRADING_CAPITAL=100000  # Initial capital in INR
MAX_LOSS_PER_DAY=2000  # Auto square-off at this loss
MAX_LOSS_PERCENTAGE=0.02  # 2% of capital

# Paper vs Live
PAPER_TRADING=true  # Switch to false for live trading
SIMULATED_SLIPPAGE_BPS=5  # Slippage in basis points for paper trading

# Feature engineering
RISK_FREE_RATE=0.06  # For Sharpe calculation
MIN_SHARPE_FOR_STRATEGY=1.5  # Gate for strategy promotion

# Backtest settings
BACKTEST_START_DATE=2020-01-01
BACKTEST_END_DATE=2024-12-31
WALK_FORWARD_TRAIN_MONTHS=6
WALK_FORWARD_TEST_MONTHS=1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

# --- Mobile backend (FastAPI) ---
# JWT signing secret (any long random string, e.g. `openssl rand -hex 32`)
MOBILE_API_SECRET=replace_me_with_a_long_random_hex_string
# The phone supplies this to /login. Treat it like a password.
MOBILE_API_SHARED_SECRET=replace_me_with_a_phone_side_password
# Set to 0 to disable the built-in demo agent (use when running the real agent).
MOBILE_API_DEMO=1

# --- Push notifications (optional) ---
# Path to a Firebase Admin SDK service-account JSON. Leave blank to disable push.
FIREBASE_CREDENTIALS=
# Comma-separated FCM device tokens to push to.
FCM_DEVICE_TOKENS=
