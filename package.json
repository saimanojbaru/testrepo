{
  "name": "offline-upi-capture",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "projects": [
      {
        "displayName": "logic",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/src/utils/__tests__/**/*.test.js"
        ],
        "transform": {
          "^.+\\.js$": [
            "babel-jest",
            {
              "configFile": "./babel.config.test.js"
            }
          ]
        }
      },
      {
        "displayName": "ui",
        "preset": "jest-expo",
        "testMatch": [
          "<rootDir>/src/**/__ui_tests__/**/*.test.js"
        ],
        "setupFiles": [
          "<rootDir>/jest.setup.ui.js"
        ],
        "transformIgnorePatterns": [
          "node_modules/(?!((jest-)?react-native|@react-native(-community)?|@react-navigation|expo(nent)?|@expo(nent)?/.*|expo-modules-core|expo-asset|expo-font|expo-linear-gradient|expo-camera|expo-status-bar|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg))"
        ]
      }
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "expo": "~51.0.0",
    "expo-camera": "~15.0.16",
    "expo-linear-gradient": "~13.0.2",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.29.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "react-test-renderer": "^18.2.0"
  },
  "private": true
}
