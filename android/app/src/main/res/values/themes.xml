<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme: framework Material with our brand palette.
         Uses DayNight so the OS dark/light setting is respected; we only
         supply dark surfaces here, light gets overridden in values-night
         (we lean dark by default since music apps tend to be dark). -->
    <style name="Theme.MashupGenerator" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/surface_0</item>
        <item name="android:colorBackground">@color/surface_0</item>
        <item name="android:colorPrimary">@color/brand_primary</item>
        <item name="android:colorAccent">@color/brand_secondary</item>
        <item name="android:colorControlActivated">@color/brand_primary</item>
        <item name="android:colorControlHighlight">#22FFFFFF</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!-- Accent ripple on Buttons -->
        <item name="android:buttonStyle">@style/MashupButton</item>
        <item name="android:editTextStyle">@style/MashupEditText</item>
    </style>

    <style name="MashupButton" parent="android:Widget.DeviceDefault.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">#0B0E12</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="MashupEditText" parent="android:Widget.DeviceDefault.EditText">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:padding">14dp</item>
        <item name="android:textCursorDrawable">@null</item>
    </style>
</resources>
