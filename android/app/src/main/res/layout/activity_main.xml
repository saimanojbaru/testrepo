<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mashup Generator"
            android:textColor="#1DB954"
            android:textSize="28sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="2dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vocals from Track A  ·  Instrumental from Track B"
            android:textColor="#888888"
            android:textSize="13sp"
            android:paddingBottom="20dp" />

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- INPUT SECTION                                                      -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Backend URL -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Backend server URL" android:textColor="#AAAAAA" android:textSize="12sp"
                android:paddingBottom="2dp" />
            <EditText
                android:id="@+id/etBaseUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="http://10.0.2.2:8000"
                android:textColor="#FFFFFF"
                android:background="#1E1E1E"
                android:padding="10dp"
                android:inputType="textUri"
                android:layout_marginBottom="18dp" />

            <!-- Track A -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TRACK A — VOCALS" android:textColor="#1DB954"
                android:textStyle="bold" android:textSize="12sp" android:letterSpacing="0.08"
                android:paddingBottom="4dp" />
            <EditText
                android:id="@+id/etTrackA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Spotify URL  or  YouTube search query"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#1E1E1E"
                android:padding="10dp"
                android:inputType="text"
                android:layout_marginBottom="18dp" />

            <!-- Track B -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TRACK B — INSTRUMENTAL" android:textColor="#2196F3"
                android:textStyle="bold" android:textSize="12sp" android:letterSpacing="0.08"
                android:paddingBottom="4dp" />
            <EditText
                android:id="@+id/etTrackB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Spotify URL  or  YouTube search query"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#1E1E1E"
                android:padding="10dp"
                android:inputType="text"
                android:layout_marginBottom="14dp" />

            <!-- YouTube-only -->
            <CheckBox
                android:id="@+id/cbYoutubeOnly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YouTube-only mode  (no Spotify credentials needed)"
                android:textColor="#CCCCCC"
                android:buttonTint="#1DB954"
                android:layout_marginBottom="10dp" />

            <!-- BPM row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:paddingEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BPM A (optional)" android:textColor="#AAAAAA" android:textSize="12sp" />
                    <EditText
                        android:id="@+id/etBpmA"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. 128"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:background="#1E1E1E"
                        android:padding="8dp"
                        android:inputType="numberDecimal" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:paddingStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BPM B (required in YT mode)" android:textColor="#AAAAAA" android:textSize="12sp" />
                    <EditText
                        android:id="@+id/etBpmB"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. 171"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:background="#1E1E1E"
                        android:padding="8dp"
                        android:inputType="numberDecimal" />
                </LinearLayout>
            </LinearLayout>

            <!-- Pitch shift -->
            <CheckBox
                android:id="@+id/cbPitchShift"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto key-compatibility pitch shift"
                android:textColor="#CCCCCC"
                android:buttonTint="#1DB954"
                android:checked="true"
                android:layout_marginBottom="20dp" />

            <!-- Generate button -->
            <Button
                android:id="@+id/btnGenerate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="GENERATE MASHUP"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="16sp"
                android:background="#1DB954" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- PROGRESS SECTION                                                   -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="40dp"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressBar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progressTint="#1DB954"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Processing…"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stem separation takes 3–10 minutes on first run.\nSubsequent runs use cached stems."
                android:textColor="#555555"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- RESULT SECTION                                                     -->
        <!-- ══════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your mashup is ready!"
                android:textColor="#1DB954"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvResultFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="▶  Play Preview"
                android:textColor="#000000"
                android:textStyle="bold"
                android:background="#1DB954"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnDownload"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="⬇  Save MP3"
                android:textColor="#1DB954"
                android:background="#1E2A1E"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start Over"
                android:textColor="#666666"
                android:background="@android:color/transparent" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
