<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface_1"
    android:padding="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to Mashup Studio"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter your backend server URL. Deploy the backend to Hugging Face Spaces (free) and paste the Space URL here — you only need to do this once."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BACKEND URL"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etSetupUrl"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input"
        android:hint="https://your-username-mashup-studio.hf.space"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textSize="13sp"
        android:inputType="textUri"
        android:singleLine="true"
        android:layout_marginBottom="10dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡  Tip: deploy this project's Dockerfile to HF Spaces (free), then paste the https://…hf.space URL above."
        android:textColor="@color/text_hint"
        android:textSize="11sp"
        android:lineSpacingExtra="2dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnSetupConnect"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_button_primary"
        android:text="Connect"
        android:textColor="@color/surface_0"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tvSetupStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

</LinearLayout>
