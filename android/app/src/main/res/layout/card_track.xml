<?xml version="1.0" encoding="utf-8"?>
<!-- Inflated dynamically for each track (2-4 tracks supported) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_hero"
    android:padding="18dp"
    android:layout_marginBottom="14dp">

    <!-- ── Header row: accent bar + label + role spinner + remove button ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <View
            android:id="@+id/accentBar"
            android:layout_width="4dp"
            android:layout_height="22dp"
            android:background="@color/brand_primary"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/tvTrackLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TRACK 1"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <Spinner
            android:id="@+id/spRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_input"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:spinnerMode="dropdown" />

        <TextView
            android:id="@+id/btnRemoveTrack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── Search row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="Search for a song…"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:textSize="14sp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:layout_marginEnd="8dp" />

        <Spinner
            android:id="@+id/spSource"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:background="@drawable/bg_input"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="8dp"
            android:spinnerMode="dropdown" />

        <TextView
            android:id="@+id/btnSearch"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="🔍"
            android:textSize="20sp"
            android:background="@drawable/bg_button_primary"
            android:layout_marginEnd="0dp" />
    </LinearLayout>

    <!-- ── Search results (populated dynamically) ── -->
    <LinearLayout
        android:id="@+id/llSearchResults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="10dp" />

    <!-- ── Selected track display ── -->
    <LinearLayout
        android:id="@+id/llSelected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSelectedTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvSelectedArtist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSelectedDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnFindHooks"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_primary"
            android:text="🔥  Find viral hooks"
            android:textColor="@color/surface_0"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── Hook summary badge ── -->
    <TextView
        android:id="@+id/tvHookSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_pill_score"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- ── Hook cards (dynamic) ── -->
    <LinearLayout
        android:id="@+id/llHooks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp" />

</LinearLayout>
