# Copy to backend/.env and fill in what you have.

DATABASE_URL=sqlite+aiosqlite:///./scalping.db
# REDIS_URL=redis://localhost:6379/0

# Upstox live feed (obtained via the Flutter app's Connect Upstox screen)
# UPSTOX_ACCESS_TOKEN=
# UPSTOX_SYMBOLS=["NSE_INDEX|Nifty 50","NSE_INDEX|Nifty Bank"]

# Claude analyst (optional — heuristic fallback used when unset)
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-7

# Telegram hourly / daily reports (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Risk caps
RISK_MAX_TRADES_PER_HOUR=6
RISK_CONSECUTIVE_LOSS_HALT=3
RISK_DAILY_LOSS_LIMIT=2000
RISK_COOLDOWN_SECONDS=180

# Signal engine tuning
SIGNAL_MOMENTUM_THRESHOLD=0.003
SIGNAL_STOP_LOSS_PCT=0.004
SIGNAL_TARGET_PCT=0.008
SIGNAL_TIME_EXIT_SECONDS=240
SIGNAL_BREAKOUT_LOOKBACK=20

# Backtesting costs
BACKTEST_BROKERAGE_PER_TRADE=20
BACKTEST_SLIPPAGE_BPS=2
BACKTEST_EXECUTION_DELAY_BARS=1
